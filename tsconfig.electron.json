{
    "compilerOptions": {
      "target": "ES2020",
      "module": "CommonJS",
      "lib": ["ES2020", "DOM"],
      "outDir": "dist/electron",
      "rootDir": "electron",
      "moduleResolution": "Node",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true
    },
    "include": ["electron/**/*.ts"],
    "exclude": ["node_modules"]
  }
  